{
  "name": "cosmic-canvas",
  "displayName": "Cosmic Canvas",
  "description": "A WYSIWYG custom editor for polishing HTML documents.",
  "version": "0.1.1",
  "publisher": "local",
  "private": true,
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/gustavorubim/cosmic-canvas.git"
  },
  "type": "module",
  "main": "./out/extension.cjs",
  "icon": "resources/icon.png",
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onCustomEditor:cosmicCanvas.htmlEditor",
    "onCommand:cosmicCanvas.openAsEditor"
  ],
  "contributes": {
    "commands": [
      {
        "command": "cosmicCanvas.openAsEditor",
        "title": "Cosmic Canvas: Open Current HTML File",
        "icon": {
          "light": "resources/cosmic-canvas-command.svg",
          "dark": "resources/cosmic-canvas-command.svg"
        }
      }
    ],
    "customEditors": [
      {
        "viewType": "cosmicCanvas.htmlEditor",
        "displayName": "Cosmic Canvas",
        "selector": [
          {
            "filenamePattern": "*.html"
          },
          {
            "filenamePattern": "*.htm"
          }
        ],
        "priority": "option"
      }
    ],
    "menus": {
      "editor/title": [
        {
          "command": "cosmicCanvas.openAsEditor",
          "when": "resourceExtname == .html || resourceExtname == .htm",
          "group": "navigation"
        }
      ]
    }
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "vscode:compile": "tsc -p tsconfig.extension.json",
    "vscode:prune": "node scripts/prune-vscode-dist.mjs",
    "vscode:prepublish": "npm run build && npm run vscode:prune && npm run vscode:compile",
    "vsix": "npm run vscode:prepublish && vsce package --no-dependencies",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "repair:native": "node scripts/repair-native-deps.mjs",
    "stress:generate": "node scripts/generate-stress-fixtures.mjs"
  },
  "dependencies": {
    "@codemirror/commands": "^6.6.2",
    "@codemirror/lang-html": "^6.4.9",
    "@codemirror/state": "^6.4.1",
    "@codemirror/view": "^6.34.1",
    "codemirror": "^6.0.1",
    "lucide-react": "^0.468.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@types/vscode": "^1.90.0",
    "@vitejs/plugin-react": "^5.0.0",
    "@vscode/vsce": "^3.2.1",
    "jsdom": "^25.0.1",
    "typescript": "^5.6.2",
    "vite": "^6.0.0",
    "vitest": "^4.1.8"
  }
}
